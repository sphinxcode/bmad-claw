{
  "name": "@sphinx/bmad-claw",
  "version": "0.1.0",
  "description": "Unofficial BMAD bridge for OpenClaw — bring BMAD agents to life",
  "type": "module",
  "main": "./index.ts",
  "license": "MIT",
  "keywords": ["bmad", "openclaw", "bridge", "agents", "bmad-method"],
  "repository": {
    "type": "git",
    "url": "https://github.com/sphinxcode/bmad-claw"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.14",
      "pluginSdkVersion": "2026.4.14"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.mjs",
    "snapshot": "node scripts/snapshot-bmad.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  }
}
